<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_home.xml — Phase 4
    Home Screen layout per 06_UI_GUIDELINES.md §Android Home Screen.
    All values are static placeholders. No live data is bound in Phase 4.
    View IDs are stable and descriptive to minimise future refactoring.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- App title -->
        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="@string/home_title"
            android:textAppearance="?attr/textAppearanceHeadline5"
            tools:ignore="UnusedAttribute" />

        <!-- Pairing Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_status_label"
            android:textAppearance="?attr/textAppearanceOverline" />

        <TextView
            android:id="@+id/tvPairingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/home_status_placeholder"
            android:textAppearance="?attr/textAppearanceBody1" />

        <!-- Connected Mac -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_connected_device_label"
            android:textAppearance="?attr/textAppearanceOverline" />

        <TextView
            android:id="@+id/tvConnectedMac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/home_connected_device_placeholder"
            android:textAppearance="?attr/textAppearanceBody1" />

        <!-- Connection Health -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_connection_health_label"
            android:textAppearance="?attr/textAppearanceOverline" />

        <TextView
            android:id="@+id/tvConnectionHealth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/home_connection_health_placeholder"
            android:textAppearance="?attr/textAppearanceBody1" />

        <!-- Permission Status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_permissions_label"
            android:textAppearance="?attr/textAppearanceOverline" />

        <TextView
            android:id="@+id/tvPermissionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/home_permissions_placeholder"
            android:textAppearance="?attr/textAppearanceBody1" />

        <!-- Last Sync (optional per UI guidelines) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_last_sync_label"
            android:textAppearance="?attr/textAppearanceOverline" />

        <TextView
            android:id="@+id/tvLastSync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="@string/home_last_sync_placeholder"
            android:textAppearance="?attr/textAppearanceBody1" />

        <!-- Settings button — navigates to SettingsFragment via MainActivity -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnManageSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_settings_button" />

    </LinearLayout>

</ScrollView>
