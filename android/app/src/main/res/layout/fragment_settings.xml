<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_settings.xml — Phase 4
    Settings screen scaffold per 06_UI_GUIDELINES.md §Android Settings.
    Sections: Permissions, Connection, Notifications, About, Privacy.

    Every section is a static placeholder in Phase 4.
    No section performs any action when viewed or tapped.
    Their purpose is to establish the future screen structure only.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar row: back button + screen title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_back" />

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:gravity="center" />

        <!-- Spacer to balance the back button width -->
        <Space
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="80dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.12" />

    <!-- Scrollable settings content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Section: Permissions -->
            <TextView
                android:id="@+id/tvSectionPermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_section_permissions"
                android:textAppearance="?attr/textAppearanceSubtitle1" />

            <TextView
                android:id="@+id/tvSectionPermissionsDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="@string/settings_section_permissions_desc"
                android:textAppearance="?attr/textAppearanceBody2" />

            <!-- Section: Connection -->
            <TextView
                android:id="@+id/tvSectionConnection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_section_connection"
                android:textAppearance="?attr/textAppearanceSubtitle1" />

            <TextView
                android:id="@+id/tvSectionConnectionDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="@string/settings_section_connection_desc"
                android:textAppearance="?attr/textAppearanceBody2" />

            <!-- Section: Notifications -->
            <TextView
                android:id="@+id/tvSectionNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_section_notifications"
                android:textAppearance="?attr/textAppearanceSubtitle1" />

            <TextView
                android:id="@+id/tvSectionNotificationsDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="@string/settings_section_notifications_desc"
                android:textAppearance="?attr/textAppearanceBody2" />

            <!-- Section: About -->
            <TextView
                android:id="@+id/tvSectionAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_section_about"
                android:textAppearance="?attr/textAppearanceSubtitle1" />

            <TextView
                android:id="@+id/tvSectionAboutDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="@string/settings_section_about_desc"
                android:textAppearance="?attr/textAppearanceBody2" />

            <!-- Section: Privacy -->
            <TextView
                android:id="@+id/tvSectionPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/settings_section_privacy"
                android:textAppearance="?attr/textAppearanceSubtitle1" />

            <TextView
                android:id="@+id/tvSectionPrivacyDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="@string/settings_section_privacy_desc"
                android:textAppearance="?attr/textAppearanceBody2" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
